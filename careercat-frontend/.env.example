NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# local keeps the browser-generated testing account behavior.
# cognito shows the email/password account screen and sends Cognito ID tokens.
NEXT_PUBLIC_AUTH_MODE=local
NEXT_PUBLIC_COGNITO_REGION=us-east-2
NEXT_PUBLIC_COGNITO_USER_POOL_ID=your-cognito-user-pool-id
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=your-cognito-app-client-id
